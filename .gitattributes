# 줄바꿈 정규화 — 저장소에는 LF로 저장, 체크아웃 시 OS에 맞춤
* text=auto eol=lf

# Windows 배치/PowerShell 스크립트는 CRLF 유지
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# 바이너리(줄바꿈 변환 금지)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.pdf binary
*.zip binary
*.hwp binary
